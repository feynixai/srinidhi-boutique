# ── web/.env.example ──────────────────────────────────────────────────────────
# Copy to web/.env.local before running the store frontend.

# Required. API server base URL.
NEXT_PUBLIC_API_URL=http://localhost:4000

# Public store URL (used for SEO metadata, sitemaps, og:url)
NEXT_PUBLIC_SITE_URL=https://thesrinidhiboutique.com

# Razorpay public key (same as server RAZORPAY_KEY_ID)
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_xxxx

# WhatsApp click-to-chat number (include country code)
NEXT_PUBLIC_WHATSAPP_NUMBER=+919876543210

# Social media URLs (shown in footer)
NEXT_PUBLIC_INSTAGRAM_URL=https://instagram.com/srinidhiboutique
NEXT_PUBLIC_FACEBOOK_URL=https://facebook.com/srinidhiboutique
NEXT_PUBLIC_YOUTUBE_URL=https://youtube.com/@srinidhiboutique

# Google OAuth — required for customer Google login
GOOGLE_CLIENT_ID=xxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=xxxxx

# NextAuth.js secret — REQUIRED in production
NEXTAUTH_SECRET=change-me-in-production
