# ── admin/.env.example ────────────────────────────────────────────────────────
# Copy to admin/.env.local before running the admin dashboard.

# Required. API server base URL.
NEXT_PUBLIC_API_URL=http://localhost:4000

# WhatsApp number for admin-side notifications
NEXT_PUBLIC_WHATSAPP_NUMBER=+919876543210

# Google OAuth — required for admin Google login
GOOGLE_CLIENT_ID=xxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=xxxxx

# NextAuth.js secret — REQUIRED in production
NEXTAUTH_SECRET=change-me-in-production
