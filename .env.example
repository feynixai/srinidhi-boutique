# Root .env.example — copy relevant sections to each sub-package.
# See server/.env.example, web/.env.example, admin/.env.example for full docs.

# ── server/.env ───────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/srinidhi_boutique
PORT=4000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000
RAZORPAY_KEY_ID=rzp_test_xxxx
RAZORPAY_KEY_SECRET=xxxx
WHATSAPP_API_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
ADMIN_WHATSAPP_PHONE=919876543210
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=youremail@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM=Srinidhi Boutique <orders@srinidhiboutique.in>
BANK_ACCOUNT_NUMBER=XXXXXXXXXXXX
BANK_IFSC=HDFC0000000
BANK_SWIFT=HDFCINBB

# ── web/.env.local ────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_SITE_URL=https://proofcrest.com
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_xxxx
NEXT_PUBLIC_WHATSAPP_NUMBER=+919876543210
NEXT_PUBLIC_INSTAGRAM_URL=https://instagram.com/srinidhiboutique
NEXT_PUBLIC_FACEBOOK_URL=https://facebook.com/srinidhiboutique
NEXT_PUBLIC_YOUTUBE_URL=https://youtube.com/@srinidhiboutique
GOOGLE_CLIENT_ID=xxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=xxxxx
NEXTAUTH_SECRET=change-me-in-production

