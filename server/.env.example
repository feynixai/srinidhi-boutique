# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/srinidhi_boutique

# ── Server ────────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development

# ── Razorpay Payments ─────────────────────────────────────────────────────────
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx

# ── WhatsApp Business API (Cloud API) ─────────────────────────────────────────
# Get from: https://developers.facebook.com/apps → WhatsApp → API Setup
WHATSAPP_API_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
ADMIN_WHATSAPP_PHONE=919876543210

# ── Email (SMTP) ──────────────────────────────────────────────────────────────
# Works with Gmail (use app password), Zoho, Brevo, etc.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=youremail@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM=Srinidhi Boutique <orders@srinidhiboutique.in>

# ── Frontend URL (for CORS + email links) ────────────────────────────────────
FRONTEND_URL=http://localhost:3000
