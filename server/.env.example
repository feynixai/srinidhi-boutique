# ── Database ──────────────────────────────────────────────────────────────────
# Required. PostgreSQL connection string.
DATABASE_URL=postgresql://user:password@localhost:5432/srinidhi_boutique

# ── Server ────────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development

# ── CORS ──────────────────────────────────────────────────────────────────────
# Frontend URL — used for CORS allow-list and email links.
FRONTEND_URL=http://localhost:3000

# ── Razorpay Payments ─────────────────────────────────────────────────────────
# Optional. Payments fall back to COD if these are absent.
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx

# ── WhatsApp Business API (Cloud API) ─────────────────────────────────────────
# Get from: https://developers.facebook.com/apps → WhatsApp → API Setup
WHATSAPP_API_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
# Admin phone that receives new-order alerts (include country code, no +)
ADMIN_WHATSAPP_PHONE=919876543210

# ── Email (SMTP) ──────────────────────────────────────────────────────────────
# Works with Gmail (use app password), Zoho, Brevo, Resend SMTP, etc.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=youremail@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM=Srinidhi Boutique <orders@srinidhiboutique.in>

# ── Bank Transfer (shown on checkout for bank payment option) ─────────────────
BANK_ACCOUNT_NUMBER=XXXXXXXXXXXX
BANK_IFSC=HDFC0000000
BANK_SWIFT=HDFCINBB
